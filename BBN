-- Main ESP loop — runs every Heartbeat to update colors, bars, distances
local _bbnEspLastErr = {}  -- throttle table for per-player errors
RunService.Heartbeat:Connect(function()
    if not (Toggles.BBN_PlayerESP and Toggles.BBN_PlayerESP.Value) then
        -- Safe iteration: collect keys first, then clear (avoid mutating
        -- the table we're iterating over)
        local toClear = {}
        for p in pairs(espRigs) do toClear[#toClear + 1] = p end
        for _, p in ipairs(toClear) do clearRig(p) end
        return
    end

    local maxDist = (Options.BBN_ESPMaxDist and Options.BBN_ESPMaxDist.Value) or 500
    local includeSelf = Toggles.BBN_ESPShowSelf and Toggles.BBN_ESPShowSelf.Value
    local myRoot = bbnGetRoot()

    for _, p in ipairs(Players:GetPlayers()) do
        local ok, err = pcall(function()
            if p == LP and not includeSelf then clearRig(p); return end

            local char = p.Character
            if not char or not char.Parent then clearRig(p); return end

            -- Distance check
            if myRoot then
                local theirRoot = char:FindFirstChild("HumanoidRootPart")
                               or char:FindFirstChild("Torso")
                               or char:FindFirstChild("RootPart")
                               or char.PrimaryPart
                if theirRoot and (theirRoot.Position - myRoot.Position).Magnitude > maxDist then
                    clearRig(p); return
                end
            end

            -- Determine role + per-role visibility
            local roleKey = getRoleKey(char)
            if not roleKey then clearRig(p); return end
            local toggleName = ROLE_TOGGLE_MAP[roleKey]
            if not (Toggles[toggleName] and Toggles[toggleName].Value) then
                clearRig(p); return
            end
            local color = (Options[toggleName .. "_Color"] and Options[toggleName .. "_Color"].Value)
                       or Color3.fromRGB(255, 255, 255)

            -- Build or reuse rig (rebuild on character swap OR if BBN
            -- destroyed our previous one — pcall catches the .Parent
            -- access error on destroyed instances)
            local rig = espRigs[p]
            local rigBroken = false
            if rig then
                local ok = pcall(function() return rig.highlight.Parent end)
                if not ok then rigBroken = true end
            end
            if not rig or rigBroken or not rig.highlight or rig.highlight.Parent ~= char then
                if rig then clearRig(p) end
                rig = buildRig(p, char, color)
            end
            if not rig then return end -- buildRig may have failed

            -- Push current values + forcefully re-assert every frame.
            -- BBN's UI/render loop destroys or disables foreign Highlights
            -- and BillboardGuis (same root cause as the Full Brightness
            -- override bug). We counter by setting all critical properties
            -- every Heartbeat — last-write-wins is on our side.
            rig.highlight.Enabled = true
            rig.highlight.FillColor = color
            rig.highlight.OutlineColor = color
            rig.highlight.FillTransparency = 0.6
            rig.highlight.OutlineTransparency = 0
            rig.highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            if rig.highlight.Parent ~= char then
                rig.highlight.Parent = char
            end

            rig.billboard.Enabled = true
            rig.billboard.AlwaysOnTop = true
            rig.billboard.MaxDistance = 1e9
            local root = char:FindFirstChild("HumanoidRootPart")
                      or char:FindFirstChild("Torso")
                      or char.PrimaryPart
            if root and rig.billboard.Adornee ~= root then
                rig.billboard.Adornee = root
            end
            if root and rig.billboard.Parent ~= root and rig.billboard.Parent ~= char then
                rig.billboard.Parent = root
            end

            rig.roleLabel.Text = ROLE_LABEL[roleKey] or roleKey
            rig.roleLabel.TextColor3 = color
            rig.nameLabel.TextColor3 = color

            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then
                local hp = hum.Health
                local mhp = hum.MaxHealth
                local frac = mhp > 0 and (hp / mhp) or 0
                rig.hpFill.Size = UDim2.fromScale(math.clamp(frac, 0, 1), 1)
                rig.hpText.Text = string.format("HP: %d/%d", math.floor(hp), math.floor(mhp))
                if frac > 0.5 then
                    rig.hpFill.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
                elseif frac > 0.25 then
                    rig.hpFill.BackgroundColor3 = Color3.fromRGB(255, 200, 60)
                else
                    rig.hpFill.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                end
            end

            local stm = char:GetAttribute("Stamina")
            local mstm = char:GetAttribute("MaxStamina")
            if stm and mstm and mstm > 0 then
                rig.stmFill.Size = UDim2.fromScale(math.clamp(stm / mstm, 0, 1), 1)
                rig.stmText.Text = string.format("STM: %d", math.floor(stm))
            else
                rig.stmFill.Size = UDim2.fromScale(0, 1)
                rig.stmText.Text = "STM: -"
            end
        end)
        if not ok then
            -- Throttle error spam: only log unique error messages once per second
            local now = tick()
            _bbnEspLastErr = _bbnEspLastErr or {}
            local key = p.Name .. ":" .. tostring(err)
            if (_bbnEspLastErr[key] or 0) < now - 1 then
                _bbnEspLastErr[key] = now
                warn("[Nullclient ESP] error for", p.Name, "→", err)
            end
        end
    end
end)

