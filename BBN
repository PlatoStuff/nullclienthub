-- Auto-Shake Minions: rapidly jitter the mouse via mousemoverel — but ONLY
-- when a minion is actually attached to the player. We detect minion-attached
-- state by scanning the local character for a descendant whose name contains
-- "Minion" (the throw module clones minion meshes onto the victim's torso).
-- If no minion is on you, we don't shake — keeps your aim sane.
-- Result is cached with 0.1s freshness to avoid scanning descendants every
-- frame (60+/sec was overkill). Latency on detection is fine — minion
-- shake-off mechanics work over multiple seconds.
local _bbnMinionLastCheck = 0
local _bbnMinionAttached = false
local function isMinionAttached()
    local now = tick()
    if now - _bbnMinionLastCheck < 0.1 then return _bbnMinionAttached end
    _bbnMinionLastCheck = now
    local char = bbnGetChar()
    if not char then _bbnMinionAttached = false; return false end
    for _, d in ipairs(char:GetDescendants()) do
        local n = d.Name
        if type(n) == "string" and (n:find("Minion") or n == "minion") then
            _bbnMinionAttached = true
            return true
        end
    end
    _bbnMinionAttached = false
    return false
end

RunService.RenderStepped:Connect(function()
    if not (Toggles.BBN_AutoShakeMinions and Toggles.BBN_AutoShakeMinions.Value) then return end
    if not mousemoverel then return end -- some executors don't expose this
    if not isMinionAttached() then return end -- only shake when actually grabbed
    local dx = (math.random() - 0.5) * 30
    local dy = (math.random() - 0.5) * 30
    pcall(mousemoverel, dx, dy)
end)

-- Perfect Barricade: while Character:HasTag("Barricading") is true,
-- force the mouse to dead center via three layers of defense:
--   1. UserInputService.MouseBehavior = LockCenter
--   2. LocalPlayer:SetAttribute("Mouselocked", true)
--   3. mousemoverel pushes cursor toward viewport center every frame
--
-- 0.3s grace window after the tag goes false handles brief tag flickers.
-- On release, force MouseBehavior to Default — game's own state may be
-- whatever and capturing it during the barricade was unreliable.
local _bbnBarricadeLastSeen = 0
local _bbnBarricadeWasLocked = false

local function bbnIsBarricading()
    local char = bbnGetChar()
    if char and char:HasTag("Barricading") then
        _bbnBarricadeLastSeen = tick()
        return true
    end
    return (tick() - _bbnBarricadeLastSeen) < 0.3
end

RunService.RenderStepped:Connect(function()
    local enabled = Toggles.BBN_PerfectBarricade and Toggles.BBN_PerfectBarricade.Value
    if not enabled then
        if _bbnBarricadeWasLocked then
            pcall(function() UserInputService.MouseBehavior = Enum.MouseBehavior.Default end)
            pcall(function() LP:SetAttribute("Mouselocked", false) end)
            _bbnBarricadeWasLocked = false
        end
        return
    end
    if not bbnIsBarricading() then
        if _bbnBarricadeWasLocked then
            -- Release — restore to Default so cursor is free for the user
            pcall(function() UserInputService.MouseBehavior = Enum.MouseBehavior.Default end)
            pcall(function() LP:SetAttribute("Mouselocked", false) end)
            _bbnBarricadeWasLocked = false
        end
        return
    end
    -- Active barricade
    _bbnBarricadeWasLocked = true
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    pcall(function() LP:SetAttribute("Mouselocked", true) end)
    if mousemoverel then
        local mouse = LP:GetMouse()
        local vp = Camera.ViewportSize
        local dx = (vp.X / 2) - mouse.X
        local dy = (vp.Y / 2) - mouse.Y
        if math.abs(dx) > 1 or math.abs(dy) > 1 then
            pcall(mousemoverel, dx, dy)
        end
    end
end)

