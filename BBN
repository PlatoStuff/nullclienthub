local activeEmote -- holds the EmoteClass instance so we can stop it later

local function fireBBNEmote()
    local emoteName = Options.BBN_EmoteName and Options.BBN_EmoteName.Value
    if not emoteName or emoteName == "" or emoteName == "(click Refresh List)" then
        Library:Notify({Title = "Emote", Description = "Refresh the list and pick an emote first", Time = 3})
        return
    end

    local char = bbnGetChar()
    if not char then
        Library:Notify({Title = "Emote", Description = "No character", Time = 3})
        return
    end

    local rep = game:GetService("ReplicatedStorage")
    local emoteModule = rep:FindFirstChild("Modules")
        and rep.Modules:FindFirstChild("Emotes")
        and rep.Modules.Emotes:FindFirstChild(emoteName)
    if not emoteModule then
        Library:Notify({Title = "Emote", Description = "Module '" .. emoteName .. "' not found", Time = 4})
        return
    end

    -- Stop any previous emote before starting new one
    if activeEmote and activeEmote.Stop then
        pcall(function() activeEmote.Stop() end)
        activeEmote = nil
    end

    local ok, err = pcall(function()
        local mod = require(emoteModule)
        -- Each emote module: t.new({character1, character2, ...}) returns
        -- an EmoteClass instance. We pass our character as the only target.
        local emoteInstance = mod.new({ char })
        activeEmote = emoteInstance
        if emoteInstance.EmoteFunc then
            emoteInstance.EmoteFunc()
        end
    end)
    if ok then
        Library:Notify({Title = "Emote", Description = "Playing: " .. emoteName, Time = 2})
    else
        Library:Notify({Title = "Emote", Description = tostring(err):sub(1, 80), Time = 5})
    end
end

EmoteBox:AddButton({ Text = "Play Selected Emote", Func = fireBBNEmote })
EmoteBox:AddButton({
