            Library:Notify({Title = ok and "Loaded" or "Failed", Description = "Nameless Admin " .. (ok and "✓" or "✗"), Time = 3})
        end)
    end,
})

-- ============= RADAR IMPLEMENTATION =============
-- Static minimap-style radar in a configurable corner. Players show as
-- colored dots based on role (uses ROLE_TOGGLE_MAP+Options for colors so
-- they match Player ESP). Camera direction = up. Distance scaled to the
-- chosen range. Requires executor Drawing API.
--
-- Draggable: hold left mouse button on the radar to move it. Custom
-- offset (when dragged) overrides the corner-based position.
local radarObjects = nil
local radarCustomCenter = nil -- {x, y} when user has dragged it
local radarDragState = { active = false, offsetX = 0, offsetY = 0 }

local function clearRadar()
    if not radarObjects then return end
    for _, obj in ipairs(radarObjects.elements) do
        pcall(function() obj:Remove() end)
    end
    radarObjects = nil
end

local function ensureRadar()
    if radarObjects then return radarObjects end
    if not Drawing then return nil end
    radarObjects = { elements = {}, dots = {} }
    local bg = Drawing.new("Circle")
    bg.Filled = true; bg.Color = Color3.new(0, 0, 0); bg.Transparency = 0.65
    bg.NumSides = 48; bg.Visible = false
    radarObjects.bg = bg; table.insert(radarObjects.elements, bg)
    local border = Drawing.new("Circle")
    border.Filled = false; border.Color = Color3.fromRGB(160, 100, 255)
    border.Thickness = 2; border.NumSides = 48; border.Transparency = 1; border.Visible = false
    radarObjects.border = border; table.insert(radarObjects.elements, border)
    local crossH = Drawing.new("Line")
    crossH.Color = Color3.fromRGB(160, 100, 255); crossH.Thickness = 1
    crossH.Transparency = 0.5; crossH.Visible = false
    radarObjects.crossH = crossH; table.insert(radarObjects.elements, crossH)
    local crossV = Drawing.new("Line")
    crossV.Color = Color3.fromRGB(160, 100, 255); crossV.Thickness = 1
    crossV.Transparency = 0.5; crossV.Visible = false
    radarObjects.crossV = crossV; table.insert(radarObjects.elements, crossV)
    local me = Drawing.new("Circle")
    me.Filled = true; me.Color = Color3.fromRGB(255, 255, 255)
    me.NumSides = 12; me.Radius = 3; me.Transparency = 1; me.Visible = false
    radarObjects.me = me; table.insert(radarObjects.elements, me)
    return radarObjects
end

-- Per-player dot pool — cleans up on player leave
local function getPlayerDot(player)
    local r = radarObjects
    if not r then return nil end
    local dot = r.dots[player]
    if not dot or not dot._alive then
        dot = Drawing.new("Circle")
        dot.Filled = true; dot.NumSides = 10; dot.Radius = 3
        dot.Transparency = 1; dot._alive = true
        r.dots[player] = dot
        table.insert(r.elements, dot)
    end
    return dot
end
Players.PlayerRemoving:Connect(function(p)
    if radarObjects and radarObjects.dots[p] then
        pcall(function() radarObjects.dots[p]:Remove() end)
        radarObjects.dots[p] = nil
    end
end)

-- Compute current radar center based on dragged offset OR corner choice
local function computeRadarCenter(size)
    local vp = Camera.ViewportSize
    if radarCustomCenter then
        return radarCustomCenter.x, radarCustomCenter.y
    end
    local pad = 24
    local pos = (Options.BBN_RadarPos and Options.BBN_RadarPos.Value) or "Bottom Right"
    if pos == "Bottom Right" then return vp.X - pad - size / 2, vp.Y - pad - size / 2
    elseif pos == "Bottom Left" then return pad + size / 2, vp.Y - pad - size / 2
    elseif pos == "Top Left" then return pad + size / 2, pad + size / 2
    else return vp.X - pad - size / 2, pad + size / 2 -- Top Right
    end
end

-- Mouse-down on the radar: start dragging if click is inside the circle
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
    if not (Toggles.BBN_Radar and Toggles.BBN_Radar.Value) then return end
    local size = (Options.BBN_RadarSize and Options.BBN_RadarSize.Value) or 180
    local cx, cy = computeRadarCenter(size)
    local mp = UserInputService:GetMouseLocation()
    local d = Vector2.new(mp.X - cx, mp.Y - cy).Magnitude
    if d <= size / 2 then
        radarDragState.active = true
        radarDragState.offsetX = mp.X - cx
        radarDragState.offsetY = mp.Y - cy
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        radarDragState.active = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if not radarDragState.active then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    local mp = UserInputService:GetMouseLocation()
    radarCustomCenter = {
        x = mp.X - radarDragState.offsetX,
        y = mp.Y - radarDragState.offsetY,
    }
end)

RunService.RenderStepped:Connect(function()
    local on = Toggles.BBN_Radar and Toggles.BBN_Radar.Value
    if not on then
        clearRadar()
        return
    end
    local r = ensureRadar()
    if not r then return end

    local size = (Options.BBN_RadarSize and Options.BBN_RadarSize.Value) or 180
    local range = (Options.BBN_RadarRange and Options.BBN_RadarRange.Value) or 100
    local cx, cy = computeRadarCenter(size)
    local center = Vector2.new(cx, cy)
    local radius = size / 2

    -- Hide everything first to avoid trails on some Drawing implementations
    for _, e in ipairs(r.elements) do
        if e ~= r.bg and e ~= r.border and e ~= r.crossH and e ~= r.crossV and e ~= r.me then
            e.Visible = false
        end
    end

    -- Background + border + cross + me marker
    r.bg.Position = center;     r.bg.Radius = radius;     r.bg.Visible = true
    r.border.Position = center; r.border.Radius = radius; r.border.Visible = true
    r.crossH.From = Vector2.new(cx - radius, cy); r.crossH.To = Vector2.new(cx + radius, cy); r.crossH.Visible = true
    r.crossV.From = Vector2.new(cx, cy - radius); r.crossV.To = Vector2.new(cx, cy + radius); r.crossV.Visible = true
    r.me.Position = center;     r.me.Visible = true

    local myRoot = bbnGetRoot()
    if not myRoot then return end
    local camCF = Camera.CFrame
    local fwd = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z)
    if fwd.Magnitude < 0.01 then return end
    fwd = fwd.Unit
    local right = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z)
    if right.Magnitude < 0.01 then return end
    right = right.Unit

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP or not p.Character then continue end
        local theirRoot = p.Character:FindFirstChild("HumanoidRootPart")
        if not theirRoot then continue end
        local rel = theirRoot.Position - myRoot.Position
        local relFlat = Vector3.new(rel.X, 0, rel.Z)
        local dist = relFlat.Magnitude
        if dist > range then continue end
        local fwdDot = relFlat:Dot(fwd)
        local rightDot = relFlat:Dot(right)
        local px = cx + (rightDot / range) * radius
        local py = cy - (fwdDot / range) * radius
        local off = Vector2.new(px - cx, py - cy)
        if off.Magnitude > radius - 4 then
            off = off.Unit * (radius - 4)
            px, py = cx + off.X, cy + off.Y
        end
        local roleKey = getRoleKey(p.Character)
        local color = Color3.fromRGB(200, 200, 200)
        if roleKey then
            local toggleName = ROLE_TOGGLE_MAP[roleKey]
            if toggleName and Options[toggleName .. "_Color"] and Options[toggleName .. "_Color"].Value then
                color = Options[toggleName .. "_Color"].Value
            end
        end
        local dot = getPlayerDot(p)
        if dot then
            dot.Position = Vector2.new(px, py)
            dot.Color = color
            dot.Visible = true
        end
    end
end)

-- Cleanup on unload — restore character to a usable state
Library:OnUnload(function()
    clearRadar()
    -- Stop fly, restore anchoring
    if bbnFlyConn then pcall(function() bbnFlyConn:Disconnect() end) end
    local root = bbnGetRoot()
    if root and bbnFlyOriginalAnchored ~= nil then
        pcall(function() root.Anchored = bbnFlyOriginalAnchored end)
    end
    local hum = bbnGetHum()
    if hum and bbnFlyOriginalAutoRotate ~= nil then
        pcall(function() hum.AutoRotate = bbnFlyOriginalAutoRotate end)
    end

    -- Restore Ghost Mode if it left the character invisible
    local char = bbnGetChar()
    if char then
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Transparency == 1 then
                pcall(function() p.Transparency = 0; p.CanCollide = true end)
            end
        end
    end

    -- Restore Lighting if FullBright was active
    if fbActive then pcall(restoreLighting); fbActive = false end

    -- Disconnect Running latch
    if _bbnRunningConn then pcall(function() _bbnRunningConn:Disconnect() end) end
    if _bbnAutoRepairConn then pcall(function() _bbnAutoRepairConn:Disconnect() end) end

    -- Destroy ESP rigs + object highlights
    for player, rig in pairs(espRigs) do
        if rig.highlight then pcall(function() rig.highlight:Destroy() end) end
        if rig.billboard then pcall(function() rig.billboard:Destroy() end) end
    end
    espRigs = {}
    for obj, rec in pairs(objHighlights) do
        if rec.highlight then pcall(function() rec.highlight:Destroy() end) end
    end
    objHighlights = {}
    for door, bb in pairs(doorBillboards) do
        pcall(function() bb:Destroy() end)
    end
    doorBillboards = {}

    -- Aimbot circle cleanup
    if bbnAimCircle then pcall(function() bbnAimCircle:Remove() end) end

    -- Music sound
    if bbnMusicSound then
        pcall(function() bbnMusicSound:Stop(); bbnMusicSound:Destroy() end)
    end

    -- Restore mouse behavior if barricade left it locked
    if _bbnBarricadeWasLocked then
        pcall(function() UserInputService.MouseBehavior = Enum.MouseBehavior.Default end)
        pcall(function() LP:SetAttribute("Mouselocked", false) end)
    end
end)

