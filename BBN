-- ============= GRADIENT HACK =============
-- Obsidian doesn't support gradients natively — we inject a UIGradient on the
-- main window frame. Heuristic search since Obsidian's internals aren't public.
task.spawn(function()
    task.wait(0.5)
    local function isMainWindowCandidate(frame)
        if not frame:IsA("Frame") then return false, 0 end
        local size = frame.AbsoluteSize
        if size.X < 400 or size.Y < 300 then return false, 0 end
        local ratio = size.X / math.max(size.Y, 1)
        local shapeScore = (ratio > 1.0 and ratio < 1.6) and 1.5 or 1.0
        return true, size.X * size.Y * shapeScore
    end
    local searchRoots = {}
    if Library.Holder then table.insert(searchRoots, Library.Holder) end
    if Library.MainFrame then table.insert(searchRoots, Library.MainFrame) end
    if Library.Container then table.insert(searchRoots, Library.Container) end
    if Library.ScreenGui then table.insert(searchRoots, Library.ScreenGui) end
    table.insert(searchRoots, game:GetService("CoreGui"))
    if LocalPlayer:FindFirstChild("PlayerGui") then
        table.insert(searchRoots, LocalPlayer.PlayerGui)
    end
    local target, bestScore = nil, 0
    for _, root in ipairs(searchRoots) do
        if root and root.GetDescendants then
            for _, child in ipairs(root:GetDescendants()) do
                local ok, score = isMainWindowCandidate(child)
                if ok and score > bestScore then
                    target, bestScore = child, score
                end
            end
        end
    end
    if target then
        if target:FindFirstChild("NullclientGradient") then
            target.NullclientGradient:Destroy()
        end
        local gradient = Instance.new("UIGradient")
        gradient.Name = "NullclientGradient"
        gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,    Color3.fromRGB(45, 18, 90)),
            ColorSequenceKeypoint.new(0.5,  Color3.fromRGB(20, 10, 40)),
            ColorSequenceKeypoint.new(1,    Color3.fromRGB(8, 4, 18)),
        })
        gradient.Rotation = 135
        gradient.Parent = target
    end
end)

