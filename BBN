        if activePoint then
            local root = bbnGetRoot()
            if root then
                local target = activePoint:IsA("BasePart") and activePoint.CFrame
                            or (activePoint:FindFirstChildWhichIsA("BasePart") and activePoint:FindFirstChildWhichIsA("BasePart").CFrame)
                if target then
                    root.CFrame = target + Vector3.new(0, 3, 0)
                    Library:Notify({Title = "Auto Escape", Description = "Teleported to escape point", Time = 3})
                    Toggles.BBN_AutoEscape:SetValue(false)
                end
            end
        end
    end
end)

