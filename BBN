local function applyObjHL(obj, color)
    local rec = objHighlights[obj]
    if not rec or not rec.highlight or rec.highlight.Parent ~= obj then
        local hl = Instance.new("Highlight")
        hl.FillTransparency = 0.7
        hl.OutlineTransparency = 0
        hl.FillColor = color
        hl.OutlineColor = color
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = obj
        objHighlights[obj] = objHighlights[obj] or {}
        objHighlights[obj].highlight = hl
        objHighlights[obj].color = color
    else
        rec.highlight.FillColor = color
        rec.highlight.OutlineColor = color
    end
end

-- Find a representative BasePart on an object (for adornee/positioning)
local function objAnchorPart(obj)
    if obj:IsA("BasePart") then return obj end
    if obj.PrimaryPart then return obj.PrimaryPart end
    return obj:FindFirstChildWhichIsA("BasePart")
end

-- applyObjBillboard: ensures a labeled billboard (with optional progress
-- bar) is parented above the object. Reuses an existing billboard if
-- present, otherwise builds one. Progress is read from any ProximityPrompt
-- descendant via ChargeStart / ChargeDuration attributes (decomp lines
-- 23653-23694 confirm this pattern). withProgress=false skips the bar.
local function applyObjBillboard(obj, labelText, color, withProgress)
    local rec = objHighlights[obj] or {}
    objHighlights[obj] = rec
    local bb = rec.billboard
    if not bb or not bb.Parent then
        local anchor = objAnchorPart(obj)
        if not anchor then return end
        bb = Instance.new("BillboardGui")
        bb.Name = "NullclientObjESP"
        bb.AlwaysOnTop = true
        bb.Size = UDim2.fromOffset(120, withProgress and 36 or 18)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.MaxDistance = 1e9
        bb.Adornee = anchor

        local lbl = Instance.new("TextLabel")
        lbl.Name = "Label"
        lbl.BackgroundTransparency = 1
        lbl.Size = UDim2.new(1, 0, 0, 16)
        lbl.Position = UDim2.new(0, 0, 0, 0)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextSize = 13
        lbl.TextStrokeTransparency = 0
        lbl.TextColor3 = color
        lbl.Text = labelText
        lbl.Parent = bb

        if withProgress then
            -- Black background bar
            local barBg = Instance.new("Frame")
            barBg.Name = "BarBg"
            barBg.Size = UDim2.new(1, -8, 0, 14)
            barBg.Position = UDim2.new(0, 4, 0, 18)
            barBg.BackgroundColor3 = Color3.new(0, 0, 0)
            barBg.BackgroundTransparency = 0.3
            barBg.BorderSizePixel = 1
            barBg.BorderColor3 = Color3.new(0, 0, 0)
            barBg.Parent = bb

            local fill = Instance.new("Frame")
            fill.Name = "Fill"
            fill.Size = UDim2.fromScale(0, 1)
            fill.BackgroundColor3 = color
            fill.BorderSizePixel = 0
            fill.Parent = barBg

            local pctText = Instance.new("TextLabel")
            pctText.Name = "Pct"
            pctText.BackgroundTransparency = 1
            pctText.Size = UDim2.fromScale(1, 1)
            pctText.Font = Enum.Font.GothamBold
            pctText.TextSize = 11
            pctText.TextStrokeTransparency = 0
            pctText.TextColor3 = Color3.new(1, 1, 1)
            pctText.Text = "0%"
            pctText.Parent = barBg
        end

        bb.Parent = anchor
        rec.billboard = bb
    end

    -- Re-assert visible state every call (defeat BBN's render-loop stripping)
    bb.Enabled = true
    local lbl = bb:FindFirstChild("Label")
    if lbl then
        lbl.Text = labelText
        lbl.TextColor3 = color
    end

    -- Update progress bar if applicable. The bar is always visible — at
    -- 0% when nobody's solving, animates 0→100% live as someone holds
    -- the ProximityPrompt. Reads from ChargeStart / ChargeDuration
    -- attributes (decomp lines 23653-23694 confirm this pattern).
    if withProgress then
        local barBg = bb:FindFirstChild("BarBg")
        local fill = barBg and barBg:FindFirstChild("Fill")
        local pct = barBg and barBg:FindFirstChild("Pct")
        local progress = 0
        for _, d in ipairs(obj:GetDescendants()) do
            if d:IsA("ProximityPrompt") then
                local cs = d:GetAttribute("ChargeStart") or 0
                local cd = d:GetAttribute("ChargeDuration") or 0
                if cs > 0 and cd > 0 then
                    local elapsed = workspace:GetServerTimeNow() - cs
                    progress = math.clamp(elapsed / cd, 0, 1)
                    break
                end
            end
        end
        if barBg then barBg.Visible = true end
        if fill then
            fill.Size = UDim2.fromScale(progress, 1)
            fill.BackgroundColor3 = color
        end
        if pct then pct.Text = string.format("%d%%", math.floor(progress * 100)) end
    end
end

local function clearObjHL(obj)
    local rec = objHighlights[obj]
    if rec then
        if rec.highlight then pcall(function() rec.highlight:Destroy() end) end
        if rec.billboard then pcall(function() rec.billboard:Destroy() end) end
    end
    objHighlights[obj] = nil
end

