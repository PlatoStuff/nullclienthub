-- ============= INFINITE STAMINA + RUNNING-LATCH =============
-- BBN's run system (decomp lines 41034-41048 and 26302-26313) checks
-- `Stamina > 0` AND `Running == true` to apply RunSpeed. When stamina
-- hits zero, the input script flips Running=false. After our heartbeat
-- restores Stamina, Running stays false until you re-press Shift.
--
-- Fix: hook GetAttributeChangedSignal("Running") on the character so the
-- moment BBN flips Running=false, we synchronously flip it back to true
-- (if our toggle is on AND shift is held). Heartbeat ordering doesn't
-- matter — attribute signals fire immediately on Set.
local _bbnRunningConn
local function bbnRebindRunningHook(char)
    if _bbnRunningConn then _bbnRunningConn:Disconnect(); _bbnRunningConn = nil end
    if not char then return end
    _bbnRunningConn = char:GetAttributeChangedSignal("Running"):Connect(function()
        if not (Toggles.BBN_InfStamina and Toggles.BBN_InfStamina.Value) then return end
        if char:GetAttribute("Running") ~= false then return end
        -- Only counter if shift is held + we're allowed to run
        if not UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then return end
        if char:HasTag("Battery") or char:GetAttribute("Ragdoll") then return end
        if not char:GetAttribute("CanRun") then return end
        -- Re-assert
