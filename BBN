-- BBN monster detection: read Character attribute. Killers are exact-match
-- "Springtrap"/"Mimic"/"Ennard". Mimic in disguise has HasTag("Imitation")
-- and Character attribute spoofs to "Survivor-Customer" — we still want
-- aimbot to track them, so we also treat HasTag("Imitation") as monster.
local function bbnIsMonster(char)
    if not char then return false end
    if char:HasTag("Imitation") then return true end -- Mimic disguise
    local cAttr = char:GetAttribute("Character")
    return cAttr == "Springtrap" or cAttr == "Mimic" or cAttr == "Ennard"
end

-- Camera-snap aimbot targeting only monsters
local function bbnPickMonster()
    local mp = UserInputService:GetMouseLocation()
    local fov = Options.BBN_AimFOV.Value
    local boneName = Options.BBN_AimBone.Value
    local best, bestDist = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP or not p.Character then continue end
        if not bbnIsMonster(p.Character) then continue end
        local part = p.Character:FindFirstChild(boneName) or p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if not (part and hum and hum.Health > 0) then continue end
        local sp, on = Camera:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
        if d < bestDist then best, bestDist = part, d end
    end
    return best
end

