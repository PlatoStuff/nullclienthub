local function captureLighting()
    if fbOriginalLighting then return end
    fbOriginalLighting = {
        Brightness     = Lighting.Brightness,
        Ambient        = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
        FogEnd         = Lighting.FogEnd,
        FogStart       = Lighting.FogStart,
        GlobalShadows  = Lighting.GlobalShadows,
    }
end

local function restoreLighting()
    if not fbOriginalLighting then return end
    pcall(function()
        Lighting.Brightness     = fbOriginalLighting.Brightness
        Lighting.Ambient        = fbOriginalLighting.Ambient
        Lighting.OutdoorAmbient = fbOriginalLighting.OutdoorAmbient
        Lighting.FogEnd         = fbOriginalLighting.FogEnd
        Lighting.FogStart       = fbOriginalLighting.FogStart
        Lighting.GlobalShadows  = fbOriginalLighting.GlobalShadows
    end)
end

