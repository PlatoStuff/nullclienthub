-- BBN Advanced Fly (PC) — uses direct CFrame translation per frame
-- instead of BodyVelocity. BBN runs server-side movement validation
-- (Requests.Movement) that can reject high-velocity body movers,
-- so we move the character manually each frame to dodge that path.
-- BBN Advanced Fly (PC) — anchors HumanoidRootPart and writes CFrame
-- directly each frame. Anchoring kills physics interactions (gravity,
-- character controller walking, BBN's PlatformStand restoration) so
-- vertical movement works cleanly. Server validates position not
-- velocity, so as long as we don't teleport huge distances per frame
-- it accepts the new position.
local bbnFlyConn
local bbnFlyOriginalAnchored
local bbnFlyOriginalAutoRotate

local function bbnStopFly()
    if bbnFlyConn then bbnFlyConn:Disconnect(); bbnFlyConn = nil end
    local root = bbnGetRoot()
    if root and bbnFlyOriginalAnchored ~= nil then
        root.Anchored = bbnFlyOriginalAnchored
    end
    local hum = bbnGetHum()
    if hum and bbnFlyOriginalAutoRotate ~= nil then
        hum.AutoRotate = bbnFlyOriginalAutoRotate
    end
    bbnFlyOriginalAnchored = nil
    bbnFlyOriginalAutoRotate = nil
end

local function bbnStartFly()
    bbnStopFly()
    local root = bbnGetRoot(); if not root then return end
    local hum = bbnGetHum()

    -- Capture originals
    bbnFlyOriginalAnchored = root.Anchored
    if hum then bbnFlyOriginalAutoRotate = hum.AutoRotate end

    -- Anchor the HRP — kills all physics
    root.Anchored = true
    if hum then hum.AutoRotate = false end

    local FLY_SPEED = 60 -- studs per second
    bbnFlyConn = RunService.Heartbeat:Connect(function(dt)
        local r = bbnGetRoot()
        if not r then return end
        -- If a respawn happened, re-anchor the new HRP
        if not r.Anchored then r.Anchored = true end

        local move = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then move += Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then move -= Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then move -= Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then move += Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0, 1, 0) end
        if move.Magnitude > 0 then move = move.Unit end

        -- Translate position by velocity * dt
        local newPos = r.Position + (move * FLY_SPEED * dt)
        -- Face camera direction (horizontal only so the body doesn't tilt up/down)
        local lookH = Vector3.new(Camera.CFrame.LookVector.X, 0, Camera.CFrame.LookVector.Z)
        if lookH.Magnitude > 0 then
            r.CFrame = CFrame.new(newPos, newPos + lookH.Unit)
        else
            r.CFrame = CFrame.new(newPos)
        end
    end)
end
Toggles.BBN_AdvFlyPC:OnChanged(function()
    if Toggles.BBN_AdvFlyPC.Value then bbnStartFly() else bbnStopFly() end
end)
LP.CharacterAdded:Connect(function()
    if Toggles.BBN_AdvFlyPC and Toggles.BBN_AdvFlyPC.Value then
