-- Snake God Mode: hook the SnakeGame module's CheckForDeath function.
-- The module table is identified by having all of: CheckForDeath, Render,
-- SpawnFruit (the real method names per decomp lines 4426-4615).
local snakeOriginalCheckForDeath
local snakeModuleTable
local function findSnakeModule()
    if snakeModuleTable then return snakeModuleTable end
    if not getgc then return nil end
    for _, item in ipairs(getgc(true)) do
        if type(item) == "table"
            and rawget(item, "CheckForDeath")
            and rawget(item, "Render")
            and rawget(item, "SpawnFruit") then
            snakeModuleTable = item
            return item
        end
    end
    return nil
end

Toggles.BBN_SnakeGod:OnChanged(function()
    local on = Toggles.BBN_SnakeGod.Value
    if on then
        local mod = findSnakeModule()
        if not mod then
            Library:Notify({Title = "Snake God", Description = "SnakeGame module not loaded — open the snake game once first", Time = 5})
            Toggles.BBN_SnakeGod:SetValue(false)
            return
        end
        if not snakeOriginalCheckForDeath then
            snakeOriginalCheckForDeath = mod.CheckForDeath
        end
        mod.CheckForDeath = function() return false end
        Library:Notify({Title = "Snake God", Description = "Immortal snake activated 🐍", Time = 3})
    else
        if snakeModuleTable and snakeOriginalCheckForDeath then
            snakeModuleTable.CheckForDeath = snakeOriginalCheckForDeath
            Library:Notify({Title = "Snake God", Description = "Restored normal collisions", Time = 2})
        end
    end
end)

