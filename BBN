-- ============= ROLE PARSING =============
-- Returns the role key (matching toggle suffix) for a character, or nil
-- if we can't determine it. Examples:
--   "Survivor-Customer"       -> "Customer"
--   "Survivor-Security Guard" -> "Security"   (note: stripped "Guard")
--   "Survivor-Lobby"          -> "Lobby"
--   "Springtrap"              -> "Springtrap"
local function getRoleKey(char)
    if not char then return nil end
    local cAttr = char:GetAttribute("Character")
    if not cAttr or cAttr == "" then return nil end
    -- Killers: whole string match
    if cAttr == "Springtrap" or cAttr == "Mimic" or cAttr == "Ennard" then
        return cAttr
    end
    -- Survivors: "Survivor-XXX" pattern
    local _, _, role = string.find(cAttr, "Survivor%-(.+)")
    if not role then return nil end
    if role:find("Customer")   then return "Customer"   end
    if role:find("Medic")      then return "Medic"      end
    if role:find("Security")   then return "Security"   end -- "Security Guard"
    if role:find("Technician") then return "Technician" end
    if role:find("Fighter")    then return "Fighter"    end
    if role:find("Lobby")      then return "Lobby"      end
    return nil
end

