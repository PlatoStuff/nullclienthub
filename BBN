-- Auto-repair watcher: looks for the GeneratorMain LocalScript when it appears.
-- PlayerGui gets recreated on respawn, so we rebind the connection each life.
local _bbnAutoRepairConn
local function bindAutoRepairWatcher()
    if _bbnAutoRepairConn then _bbnAutoRepairConn:Disconnect(); _bbnAutoRepairConn = nil end
    local pg = LP:WaitForChild("PlayerGui", 5)
    if not pg then return end
    _bbnAutoRepairConn = pg.DescendantAdded:Connect(function(d)
        if not (Toggles.BBN_AutoRepairGen and Toggles.BBN_AutoRepairGen.Value) then return end
        if d:IsA("LocalScript") and d.Name == "GeneratorMain" then
            local minDelay = Options.BBN_RepairMin.Value or 0.5
            local maxDelay = Options.BBN_RepairMax.Value or 1.5
            task.wait(minDelay + math.random() * (maxDelay - minDelay))
            local ev = d:FindFirstChild("Event")
            if ev and ev:IsA("RemoteEvent") then
                pcall(function()
                    ev:FireServer({Lever = true, Switches = true, Wires = true})
                end)
                Library:Notify({Title = "Generator", Description = "Auto-repaired", Time = 2})
            end
        end
    end)
end
