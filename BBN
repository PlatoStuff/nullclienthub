-- Silent Aim: redirect Vector3 args in FireServer when enabled
if hookmetamethod and not getgenv().__nullclient_bbn_namecall_hooked then
    getgenv().__nullclient_bbn_namecall_hooked = true
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if Toggles.BBN_SilentAim and Toggles.BBN_SilentAim.Value and method == "FireServer" then
            local target = bbnPickMonster()
            if target then
                local args = {...}
                local changed = false
                for i, a in ipairs(args) do
                    if typeof(a) == "Vector3" then
                        args[i] = target.Position
                        changed = true
                    end
                end
                if changed then
                    return oldNamecall(self, table.unpack(args))
                end
            end
        end
        return oldNamecall(self, ...)
    end)
end

