-- Ghost Mode restore on toggle-off: snapshots transparency on toggle-on,
-- restores on toggle-off. Without this, you'd stay invisible forever.
local _bbnGhostSnapshot
Toggles.BBN_GhostMode:OnChanged(function()
    local char = bbnGetChar(); if not char then return end
    if Toggles.BBN_GhostMode.Value then
        -- Snapshot only the first time on; if user respawns, the snapshot
        -- becomes stale but new parts default to visible so it's harmless.
        _bbnGhostSnapshot = {}
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") then
                _bbnGhostSnapshot[p] = {transparency = p.Transparency, canCollide = p.CanCollide}
            elseif p:IsA("Decal") then
                _bbnGhostSnapshot[p] = {transparency = p.Transparency}
            end
        end
    else
        -- Restore from snapshot, then sweep any new parts back to default visible
        if _bbnGhostSnapshot then
            for inst, snap in pairs(_bbnGhostSnapshot) do
                if inst.Parent then
                    if inst:IsA("BasePart") then
                        inst.Transparency = snap.transparency
                        inst.CanCollide = snap.canCollide
                    elseif inst:IsA("Decal") then
                        inst.Transparency = snap.transparency
                    end
                end
            end
            _bbnGhostSnapshot = nil
        end
        -- Failsafe: any part still at transparency 1 that wasn't in snapshot
        -- gets reset to 0 (better than leaving stuck invisible)
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.Transparency == 1 then
                p.Transparency = 0
                p.CanCollide = true
            end
        end
    end
end)

