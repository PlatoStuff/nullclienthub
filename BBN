-- Per-second loop: refresh all object ESP from authoritative locations
task.spawn(function()
    while task.wait(0.5) do
        if Library.Unloaded then break end

        local map = getGameMap()
        if not map then continue end
        -- Tasks-related objects moved into a Tasks subfolder in the
        -- game update. Fall back to top-level paths for older versions.
        local tasks = map:FindFirstChild("Tasks")

        -- GENERATORS — highlight + label + progress bar
        local gens = (tasks and tasks:FindFirstChild("Generators"))
                  or map:FindFirstChild("Generators")
        if gens then
            for _, g in ipairs(gens:GetChildren()) do
                if Toggles.BBN_HighlightGens and Toggles.BBN_HighlightGens.Value then
                    local color = Options.BBN_GenColor.Value
                    applyObjHL(g, color)
                    applyObjBillboard(g, "Generator", color, true)
                else clearObjHL(g) end
            end
        end

        -- BATTERIES — highlight + label
        local bats = (tasks and tasks:FindFirstChild("Batteries"))
                  or map:FindFirstChild("Batteries")
        if bats then
            for _, b in ipairs(bats:GetChildren()) do
                if Toggles.BBN_HighlightBatteries and Toggles.BBN_HighlightBatteries.Value then
                    local color = Options.BBN_BatteryColor.Value
                    applyObjHL(b, color)
                    applyObjBillboard(b, "Battery", color, false)
                else clearObjHL(b) end
            end
        end

        -- FUSES — highlight + label + progress bar
        local fuses = (tasks and tasks:FindFirstChild("FuseBoxes"))
                   or map:FindFirstChild("FuseBoxes") or map:FindFirstChild("Fuses")
        if fuses then
            for _, f in ipairs(fuses:GetChildren()) do
                if Toggles.BBN_HighlightFuses and Toggles.BBN_HighlightFuses.Value then
                    local color = Options.BBN_FuseColor.Value
                    applyObjHL(f, color)
                    applyObjBillboard(f, "Fuse", color, true)
                else clearObjHL(f) end
            end
        end

        -- DOORS (with hit counter billboard)
        local doors = map:FindFirstChild("Doors")
        if doors then
            for _, d in ipairs(doors:GetChildren()) do
                if Toggles.BBN_DoorHits and Toggles.BBN_DoorHits.Value then
                    applyDoorBillboard(d)
                    local bb = doorBillboards[d]
                    if bb then
                        -- BBN doors expose a "Breaks" attribute (default 3,
                        -- decrements with each killer hit). Confirmed via
                        -- runtime debug.
                        local hits = d:GetAttribute("Breaks")
                        local lbl = bb:FindFirstChild("HitsLabel")
                        if lbl then
                            lbl.Text = "(" .. tostring(hits or "?") .. ")"
                        end
                    end
                else clearDoorBillboard(d) end
            end
        end

        -- BEAR TRAPS / MINIONS — use the cached set (maintained by listeners
        -- below). Avoids the expensive workspace:GetDescendants() scan we
        -- previously ran every 0.5s.
        for obj in pairs(_bbnTrackedObjects) do
            if not obj.Parent then _bbnTrackedObjects[obj] = nil; continue end
            local kind = _bbnTrackedObjects[obj]
            if kind == "trap" then
                if Toggles.BBN_BearTrapESP and Toggles.BBN_BearTrapESP.Value then
                    local color = Options.BBN_TrapColor.Value
                    applyObjHL(obj, color)
                    applyObjBillboard(obj, "Trap", color, false)
                else clearObjHL(obj) end
            elseif kind == "minion" then
                if Toggles.BBN_MinionESP and Toggles.BBN_MinionESP.Value then
                    local color = Options.BBN_MinionColor.Value
                    applyObjHL(obj, color)
                    applyObjBillboard(obj, "Minion", color, false)
                else clearObjHL(obj) end
            end
        end
    end
end)

