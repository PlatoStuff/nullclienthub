    if type(n) ~= "string" then return nil end
    local lower = n:lower()
    -- Traps: "Beartrap" / "BearTrap" / "Bear Trap" / "Trap"
    if lower:find("beartrap") or lower == "trap" or lower:find("bear trap") then
        return "trap"
    end
    -- Minions: "Minion" / "EnnardMinion"
    if lower:find("minion") then return "minion" end
    return nil
end
