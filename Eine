getgenv().__nullclient_pickTarget = function()
    local s = getgenv().__nullclient_silentaim
    if not s or not s.enabled then return nil end
    local mp = UserInputService:GetMouseLocation()
    local best, bestDist = nil, s.fov

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local sameTeam = s.teamCheck and LocalPlayer.Team and p.Team == LocalPlayer.Team
            if not sameTeam then
                local part = p.Character:FindFirstChild(s.target)
                          or p.Character:FindFirstChild("HumanoidRootPart")
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if part and hum and hum.Health > 0 then
                    local sp, on = Camera:WorldToViewportPoint(part.Position)
                    if on then
                        local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
                        if d < bestDist then
                            local visible = true
                            if s.visCheck then
                                local rp = RaycastParams.new()
                                rp.FilterType = Enum.RaycastFilterType.Exclude
                                rp.FilterDescendantsInstances = {LocalPlayer.Character, p.Character}
                                local origin = Camera.CFrame.Position
                                local res = workspace:Raycast(origin, part.Position - origin, rp)
                                if res and (res.Position - part.Position).Magnitude > 4 then
                                    visible = false
                                end
                            end
                            if visible then best, bestDist = part, d end
                        end
                    end
                end
            end
        end
    end
    return best
end

if hookmetamethod and not getgenv().__nullclient_namecall_hooked then
    getgenv().__nullclient_namecall_hooked = true
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local s = getgenv().__nullclient_silentaim
        if s and s.enabled and method == "FireServer" then
            local pickFn = getgenv().__nullclient_pickTarget
            if pickFn then
                local mb2ok = (not s.requireMB2) or
                    UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
                if mb2ok then
                    local target = pickFn()
                    if target then
                        local args = {...}
                        local changed = false
                        for i, arg in ipairs(args) do
                            if typeof(arg) == "Vector3" then
                                args[i] = target.Position
                                changed = true
                            end
                        end
                        if changed then
                            return oldNamecall(self, table.unpack(args))
                        end
                    end
                end
            end
        end
        return oldNamecall(self, ...)
    end)
end

