local function runHub(name, url)
    Library:Notify({Title = "Loading", Description = name .. "...", Time = 3})
    task.spawn(function()
        local ok, err = pcall(function()
            local body = game:HttpGet(url, true)
            local fn = loadstring(body)
            if not fn then error("loadstring returned nil") end
            fn()
        end)
        if ok then
            Library:Notify({Title = "Loaded", Description = name .. " ✓", Time = 3})
        else
            Library:Notify({Title = "Failed", Description = name .. ": " .. tostring(err):sub(1, 80), Time = 6})
        end
    end)
end

