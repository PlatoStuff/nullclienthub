local savedConfigs = setmetatable({}, {__mode = "k"})
local function snapshotConfig(cfg)
    if savedConfigs[cfg] then return end
    local snap = {}
    for _, f in ipairs(recoilFields) do snap[f] = cfg[f] end
    for _, f in ipairs(spreadFields) do snap[f] = cfg[f] end
    savedConfigs[cfg] = snap
end
local function restoreFields(fields)
    if not ammoUpvalue then return end
    local cfg = ammoUpvalue.curConfig
    if type(cfg) ~= "table" then return end
    local snap = savedConfigs[cfg]; if not snap then return end
    for _, f in ipairs(fields) do
        if snap[f] ~= nil then cfg[f] = snap[f] end
    end
end

