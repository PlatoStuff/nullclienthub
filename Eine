local boxLines = {}  -- per-player: { top, bottom, left, right, fill, healthBg, healthFg }

local function clearBoxFor(player)
    local b = boxLines[player]; if not b then return end
    for _, d in pairs(b) do if d and d.Remove then d:Remove() end end
    boxLines[player] = nil
end
local function clearAllBoxes()
    for p in pairs(boxLines) do clearBoxFor(p) end
end

Players.PlayerRemoving:Connect(clearBoxFor)

Toggles.BoxESP:OnChanged(function()
    if not Toggles.BoxESP.Value then clearAllBoxes() end
end)
Options.BoxColor:OnChanged(function()
    for _, b in pairs(boxLines) do
        for k, d in pairs(b) do
            if d and d.Color and k ~= "healthBg" and k ~= "healthFg" then
                d.Color = Options.BoxColor.Value
            end
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not Drawing then return end
    local on = Toggles.BoxESP.Value or Toggles.Healthbar.Value
    if not on then clearAllBoxes(); return end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not isEnemy(player) then clearBoxFor(player); continue end
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if not (char and hum and root) then clearBoxFor(player); continue end

        local pos, on = Camera:WorldToViewportPoint(root.Position)
        if not on or pos.Z <= 0 then
            local b = boxLines[player]
            if b then for _, d in pairs(b) do d.Visible = false end end
            continue
        end

        -- 2D box dimensions based on character bounding box
        local size = Vector2.new(2000 / pos.Z, 3000 / pos.Z)
        local x, y = pos.X - size.X / 2, pos.Y - size.Y / 2

        local b = boxLines[player]
        if not b then
            b = {
                top    = Drawing.new("Line"),
                bottom = Drawing.new("Line"),
                left   = Drawing.new("Line"),
                right  = Drawing.new("Line"),
                fill   = Drawing.new("Square"),
                healthBg = Drawing.new("Square"),
                healthFg = Drawing.new("Square"),
            }
            for k, d in pairs(b) do
                d.Visible = false
                if d.Thickness then d.Thickness = 1 end
                if d.Transparency then d.Transparency = 1 end
                if k == "fill" then
                    d.Filled = true; d.Transparency = 0.25
                elseif k == "healthBg" then
                    d.Filled = true; d.Color = Color3.fromRGB(20,20,20)
                elseif k == "healthFg" then
                    d.Filled = true
                else
                    d.Color = Options.BoxColor.Value
                end
            end
            boxLines[player] = b
        end

        local color = Options.BoxColor.Value
        local thick = Options.BoxThick.Value

        -- Box render
        if Toggles.BoxESP.Value then
            b.top.From    = Vector2.new(x, y);             b.top.To    = Vector2.new(x + size.X, y)
            b.bottom.From = Vector2.new(x, y + size.Y);    b.bottom.To = Vector2.new(x + size.X, y + size.Y)
            b.left.From   = Vector2.new(x, y);             b.left.To   = Vector2.new(x, y + size.Y)
            b.right.From  = Vector2.new(x + size.X, y);    b.right.To  = Vector2.new(x + size.X, y + size.Y)
            for _, k in ipairs({"top","bottom","left","right"}) do
                b[k].Color = color; b[k].Thickness = thick; b[k].Visible = true
            end
            if Toggles.BoxFilled.Value then
                b.fill.Position = Vector2.new(x, y)
                b.fill.Size = size
                b.fill.Color = color
                b.fill.Visible = true
            else b.fill.Visible = false end
        else
            for _, k in ipairs({"top","bottom","left","right","fill"}) do
                b[k].Visible = false
            end
        end

        -- Healthbar render (left side of box)
        if Toggles.Healthbar.Value then
            local hpPct = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
            local hbWidth, hbX = 3, x - 6
            b.healthBg.Position = Vector2.new(hbX, y)
            b.healthBg.Size = Vector2.new(hbWidth, size.Y)
            b.healthBg.Visible = true
            local fgH = size.Y * hpPct
            b.healthFg.Position = Vector2.new(hbX, y + size.Y - fgH)
            b.healthFg.Size = Vector2.new(hbWidth, fgH)
            -- color shifts red→green based on HP
            b.healthFg.Color = Color3.fromRGB(
                math.floor(255 * (1 - hpPct)),
                math.floor(220 * hpPct),
                40
            )
            b.healthFg.Visible = true
        else
            b.healthBg.Visible = false
            b.healthFg.Visible = false
        end
    end
end)

