    if not ammoUpvalue then return end
    if infAmmoEnabled then ammoUpvalue.Ammo = 999999 end

    local cfg = ammoUpvalue.curConfig
    if type(cfg) ~= "table" then return end

    if Toggles.NoRecoil.Value or Toggles.NoSpread.Value then
        snapshotConfig(cfg)
