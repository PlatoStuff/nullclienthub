-- ====================================================
-- EINE-ONLY FEATURES (Carbon Engine guns + silent aim)
-- ====================================================
local infAmmoEnabled = false
local ammoUpvalue = nil

local function hookAmmo(silent)
    if ammoUpvalue then return true end
    if not getgc or not debug or not debug.getconstants or not debug.getupvalue then
        if not silent then Library:Notify({Title = "Inf Ammo", Description = "Executor missing getgc / debug.getconstants", Time = 5}) end
        return false
    end

    local function isGunControlFn(consts)
        local hasAim, hasL2, hasL3 = false, false, false
        for _, c in pairs(consts) do
            if c == "Aim" then hasAim = true
            elseif c == "ButtonL2" then hasL2 = true
            elseif c == "ButtonL3" then hasL3 = true end
        end
        return hasAim and hasL2 and hasL3
    end

    local found = nil
    for _, fn in pairs(getgc(false)) do
        if type(fn) == "function" then
            local okC, consts = pcall(debug.getconstants, fn)
            if okC and type(consts) == "table" and isGunControlFn(consts) then
                for i = 1, 30 do
                    local okU, val = pcall(debug.getupvalue, fn, i)
                    if not okU then break end
                    if type(val) == "table" and type(rawget(val, "Ammo")) == "number" then
                        found = val
                        break
                    end
                end
                if found then break end
            end
        end
    end

    if not found then
        if not silent then Library:Notify({Title = "Inf Ammo", Description = "Ammo table not found — equip gun, fire once, retry", Time = 5}) end
        return false
    end
    ammoUpvalue = found
    return true
end

