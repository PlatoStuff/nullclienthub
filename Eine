local highlights, nameLabels = {}, {}

local function isEnemy(player)
    if not (Toggles.TeamCheck and Toggles.TeamCheck.Value) then return true end
    if not LocalPlayer.Team then return true end
    return player.Team ~= LocalPlayer.Team
end

local function clearESPFor(player)
    if highlights[player] then highlights[player]:Destroy(); highlights[player] = nil end
    if nameLabels[player] then
        if nameLabels[player].Parent then nameLabels[player].Parent:Destroy() end
        nameLabels[player] = nil
    end
end

local function clearAllESP()
    for p in pairs(highlights) do clearESPFor(p) end
    for p in pairs(nameLabels) do clearESPFor(p) end
end

local function applyESPTo(player)
    if player == LocalPlayer then return end
    local char = player.Character
    if not char or not char.Parent then return end
    if not isEnemy(player) then clearESPFor(player); return end

    local espOn = Toggles.ESP and Toggles.ESP.Value
    local nameOn = Toggles.NameESP and Toggles.NameESP.Value
    local distOn = Toggles.DistanceESP and Toggles.DistanceESP.Value

    if espOn then
        local hl = highlights[player]
        if not hl or hl.Parent ~= char then
            if hl then hl:Destroy() end
            hl = Instance.new("Highlight")
            hl.FillColor = (Options.ESPColor and Options.ESPColor.Value) or Color3.fromRGB(255,0,0)
            hl.OutlineColor = Color3.new(1, 1, 1)
            hl.FillTransparency = 0.5
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Parent = char
            highlights[player] = hl
        end
    elseif highlights[player] then
        highlights[player]:Destroy(); highlights[player] = nil
    end

    if nameOn or distOn then
        local lbl = nameLabels[player]
        local bb = lbl and lbl.Parent
        local stale = not lbl or not bb or not bb.Adornee or bb.Adornee.Parent ~= char
        if stale then
            if bb then bb:Destroy() end
            local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            if not head then return end
            bb = Instance.new("BillboardGui")
            bb.Size = UDim2.new(0, 200, 0, 40)
            bb.StudsOffset = Vector3.new(0, 2.5, 0)
            bb.AlwaysOnTop = true
            bb.MaxDistance = math.huge
            bb.Adornee = head
            bb.Parent = char

            lbl = Instance.new("TextLabel")
            lbl.BackgroundTransparency = 1
            lbl.Size = UDim2.fromScale(1, 1)
            lbl.Font = Enum.Font.GothamBold
            lbl.TextSize = 14
            lbl.TextColor3 = Color3.new(1, 1, 1)
            lbl.TextStrokeTransparency = 0
            lbl.Parent = bb
            nameLabels[player] = lbl
        end
    elseif nameLabels[player] then
        if nameLabels[player].Parent then nameLabels[player].Parent:Destroy() end
        nameLabels[player] = nil
    end
end

local function refreshAllESP()
    for _, p in ipairs(Players:GetPlayers()) do applyESPTo(p) end
end

local function hookPlayer(p)
    p.CharacterAdded:Connect(function(char)
        clearESPFor(p)
        char:WaitForChild("Humanoid", 10)
        char:WaitForChild("Head", 10)
        task.wait(0.3)
        applyESPTo(p)
    end)
end
Players.PlayerAdded:Connect(hookPlayer)
for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then hookPlayer(p) end
end
Players.PlayerRemoving:Connect(clearESPFor)

Options.ESPColor:OnChanged(function()
    for _, hl in pairs(highlights) do hl.FillColor = Options.ESPColor.Value end
end)
Toggles.ESP:OnChanged(refreshAllESP)
Toggles.NameESP:OnChanged(refreshAllESP)
Toggles.DistanceESP:OnChanged(refreshAllESP)
Toggles.TeamCheck:OnChanged(function() clearAllESP(); refreshAllESP() end)

RunService.RenderStepped:Connect(function()
    local nameOn = Toggles.NameESP and Toggles.NameESP.Value
    local distOn = Toggles.DistanceESP and Toggles.DistanceESP.Value
    if not (nameOn or distOn) then return end
    local root = getRoot()
    for player, lbl in pairs(nameLabels) do
        if lbl.Parent and player.Character then
            local txt = ""
            if nameOn then txt = player.Name end
            if distOn and root then
                local theirRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if theirRoot then
                    local d = math.floor((root.Position - theirRoot.Position).Magnitude)
                    txt = txt .. (nameOn and " " or "") .. "[" .. d .. "m]"
                end
            end
            lbl.Text = txt
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        if Library.Unloaded then break end
        local anyOn = (Toggles.ESP and Toggles.ESP.Value)
                   or (Toggles.NameESP and Toggles.NameESP.Value)
                   or (Toggles.DistanceESP and Toggles.DistanceESP.Value)
        if anyOn then
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer then applyESPTo(p) end
            end
        end
    end
end)

