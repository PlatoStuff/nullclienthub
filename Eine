-- Helper: SpecialType="Player" dropdown's .Value can be either the Player
-- instance or a name string depending on Obsidian version. Handle both.
local function resolveTPTarget()
    local v = Options.TPTarget.Value
    if not v or v == "" then return nil end
    if typeof(v) == "Instance" then return v end
    if type(v) == "string" then return Players:FindFirstChild(v) end
    return nil
end

TPBox:AddButton({ Text = "Teleport to Player", Func = function()
    local target = resolveTPTarget()
    if not target then
        Library:Notify({Title = "TP", Description = "Pick a player from the dropdown first", Time = 3}); return
    end
    if not target.Character then
        Library:Notify({Title = "TP", Description = "Target has no character (respawning?)", Time = 3}); return
    end
    local theirRoot = target.Character:FindFirstChild("HumanoidRootPart")
    local myRoot = getRoot()
    if theirRoot and myRoot then
        myRoot.CFrame = theirRoot.CFrame + Vector3.new(0, 3, 0)
    end
end })

