UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if not Toggles.ClickTP or not Toggles.ClickTP.Value then return end
    local pickerVal = Options.ClickTPKey and Options.ClickTPKey.Value
    if not pickerVal then return end
    local matched = (input.KeyCode == Enum.KeyCode[pickerVal])
        or (input.UserInputType.Name == pickerVal)
    if matched then
        local mouse = LocalPlayer:GetMouse()
        local hit = mouse.Hit
        local root = getRoot()
        if hit and root then
            root.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
