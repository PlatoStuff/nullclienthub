local freeCamConn
local freeCamCFrame
Toggles.FreeCam:OnChanged(function()
    if Toggles.FreeCam.Value then
        freeCamCFrame = Camera.CFrame
        Camera.CameraType = Enum.CameraType.Scriptable
        freeCamConn = RunService.RenderStepped:Connect(function(dt)
            local mv = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv += freeCamCFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv -= freeCamCFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv -= freeCamCFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv += freeCamCFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) then mv += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then mv -= Vector3.new(0,1,0) end
            if mv.Magnitude > 0 then mv = mv.Unit end
            local speed = 100
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then speed = 250 end
            freeCamCFrame = freeCamCFrame + (mv * speed * dt)
            -- mouse-look
            local delta = UserInputService:GetMouseDelta()
            freeCamCFrame = CFrame.new(freeCamCFrame.Position)
                * CFrame.Angles(0, math.rad(-delta.X * 0.4), 0)
                * (freeCamCFrame - freeCamCFrame.Position)
                * CFrame.Angles(math.rad(-delta.Y * 0.4), 0, 0)
            Camera.CFrame = freeCamCFrame
        end)
    else
        if freeCamConn then freeCamConn:Disconnect(); freeCamConn = nil end
        Camera.CameraType = Enum.CameraType.Custom
        local h = getHumanoid()
        if h then Camera.CameraSubject = h end
    end
end)

