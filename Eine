local aimbotCircle
if Drawing then
    aimbotCircle = Drawing.new("Circle")
    aimbotCircle.Visible = false; aimbotCircle.Filled = false
    aimbotCircle.Thickness = 1; aimbotCircle.Transparency = 1
    aimbotCircle.NumSides = 64
    aimbotCircle.Color = Color3.fromRGB(160, 100, 255)
end

local function aimbotPickTarget()
    local mp = UserInputService:GetMouseLocation()
    local fov = Options.AimbotFOV.Value
    local partName = Options.AimbotPart.Value
    local visCheck = Toggles.AimbotVis.Value
    local teamCheck = Toggles.AimbotTeam.Value

    local best, bestDist = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local sameTeam = teamCheck and LocalPlayer.Team and p.Team == LocalPlayer.Team
            if not sameTeam then
                local part = p.Character:FindFirstChild(partName)
                          or p.Character:FindFirstChild("HumanoidRootPart")
                local hum = p.Character:FindFirstChildOfClass("Humanoid")
                if part and hum and hum.Health > 0 then
                    local sp, on = Camera:WorldToViewportPoint(part.Position)
                    if on then
                        local d = (Vector2.new(sp.X, sp.Y) - mp).Magnitude
                        if d < bestDist then
                            local visible = true
                            if visCheck then
                                local rp = RaycastParams.new()
                                rp.FilterType = Enum.RaycastFilterType.Exclude
                                rp.FilterDescendantsInstances = {LocalPlayer.Character, p.Character}
                                local origin = Camera.CFrame.Position
                                local res = workspace:Raycast(origin, part.Position - origin, rp)
                                if res and (res.Position - part.Position).Magnitude > 4 then
                                    visible = false
                                end
                            end
                            if visible then best, bestDist = part, d end
                        end
                    end
                end
            end
        end
    end
    return best
end

RunService.RenderStepped:Connect(function()
    -- FOV circle render
    if aimbotCircle then
        local show = (Toggles.Aimbot.Value and Toggles.AimbotShowFOV.Value) and true or false
        aimbotCircle.Visible = show
        if show then
            local mp = UserInputService:GetMouseLocation()
            aimbotCircle.Position = Vector2.new(mp.X, mp.Y)
            aimbotCircle.Radius = Options.AimbotFOV.Value or 250
        end
    end

    -- Aimbot snap
    if not Toggles.Aimbot.Value then return end
    if not Options.AimbotKey:GetState() then return end
    local target = aimbotPickTarget()
    if not target then return end
    local smooth = Options.AimbotSmooth.Value
    local desired = CFrame.new(Camera.CFrame.Position, target.Position)
    if smooth <= 0.01 then
        Camera.CFrame = desired
    else
        Camera.CFrame = Camera.CFrame:Lerp(desired, 1 - smooth)
    end
end)

